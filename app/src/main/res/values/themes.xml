<resources xmlns:tools="http://schemas.android.com/tools">
    <!--
        Bootstrap XML theme used only before Compose takes over.
        AppCompat.DayNight is always available and keeps the status bar transparent.
        All visual theming is handled by LocateMeTheme (Compose Material 3).
    -->
    <style name="Theme.LocateMe" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar" tools:targetApi="23">false</item>
    </style>
</resources>